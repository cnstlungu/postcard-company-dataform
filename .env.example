# ── Dataform project config ────────────────────────────────────────────────────
# Edit workflow_settings.yaml and set:
#   defaultProject: your-gcp-project-here
#   vars:
#     gcs_parquet_path: gs://your-bucket-here/parquet

# ── Data generator ─────────────────────────────────────────────────────────────
# Local directory where generate.py writes parquet files before upload to GCS.
# Defaults to generator/output/ if not set.
export INPUT_FILES_PATH=./generator/output

# After running the generator, upload the parquet files to GCS:
#   gsutil -m cp ./generator/output/*.parquet gs://your-bucket-here/parquet/
