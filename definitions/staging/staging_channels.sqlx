config {
  tags: ["staging"],
  type: "view",
  schema: "postcard_company_staging",
  description: "Staged channels — adds surrogate key alias"
}

WITH staging_channels AS (
  SELECT
    channel_id,
    channel_name
  FROM ${ref("postcard_company_raw", "raw_channels")}
)

SELECT
  channel_id AS channel_key,
  channel_id AS original_channel_id,
  channel_name
FROM staging_channels
