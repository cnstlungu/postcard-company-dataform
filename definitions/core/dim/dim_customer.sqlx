config {
  tags: ["core", "dim"],
  type: "table",
  schema: "postcard_company_core",
  description: "Customer dimension — unified across direct and reseller channels",
  uniqueKey: ["customer_key"]
}

SELECT
  customer_key,
  original_customer_id,
  customer_first_name,
  customer_last_name,
  customer_email,
  customer_phone,
  customer_address,
  customer_city,
  customer_country,
  customer_postal_code,
  sales_agent_key
FROM ${ref("postcard_company_staging", "staging_customers")}
